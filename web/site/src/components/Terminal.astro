---
// Terminal-card showing real `kdo` output. Static — typography does the work.
// Uses Geist Mono with tabular numerics. Very subtle window chrome.
---

<div class="glass relative w-full max-w-3xl rounded-2xl p-1 shadow-[0_30px_80px_-20px_rgba(20,30,50,0.18)]">
  <div class="rounded-[14px] bg-canvas-2/70 px-5 py-4 sm:px-6 sm:py-5">
    <!-- chrome -->
    <div class="flex items-center justify-between border-b border-fog/60 pb-3">
      <div class="flex items-center gap-1.5">
        <span aria-hidden="true" class="block h-2.5 w-2.5 rounded-full bg-fog"></span>
        <span aria-hidden="true" class="block h-2.5 w-2.5 rounded-full bg-fog"></span>
        <span aria-hidden="true" class="block h-2.5 w-2.5 rounded-full bg-fog"></span>
      </div>
      <span class="font-mono text-[11px] tracking-tight text-ink-3">~/my-monorepo</span>
    </div>

    <!-- output -->
    <pre class="mt-3 overflow-x-auto font-mono text-[13px] leading-6 text-ink-2 tabular-nums sm:text-sm"><code><span class="text-ink-3">$</span> <span class="text-ink">kdo init</span>
<span class="text-ink-3">  discovering workspace…</span>
<span class="text-tide">✓</span> <span class="text-ink">11 projects</span> <span class="text-ink-3">found</span> <span class="text-ink-3">(rust · ts · python · anchor · go)</span>
<span class="text-tide">✓</span> <span class="text-ink-3">graph built —</span> <span class="text-ink">14 edges, 0 cycles</span>
<span class="text-tide">✓</span> <span class="text-ink-3">context generated —</span> <span class="text-ink">11 files, 28k tokens</span>

<span class="text-ink-3">$</span> <span class="text-ink">kdo run ci --filter vault-program</span>
<span class="text-ink-3">[</span><span class="text-tide">vault-program:lint</span><span class="text-ink-3">]</span> <span class="text-ink">cargo clippy --all-targets -- -D warnings</span>
<span class="text-ink-3">[</span><span class="text-tide">vault-program:lint</span><span class="text-ink-3">]</span> <span class="text-ink-3">done</span>
<span class="text-ink-3">[</span><span class="text-tide">vault-program:test</span><span class="text-ink-3">]</span> <span class="text-ink">cargo nextest run</span>
<span class="text-ink-3">[</span><span class="text-tide">vault-program:test</span><span class="text-ink-3">]</span> <span class="text-ink-3">42 passed in 1.8s</span></code></pre>
  </div>
</div>
