---
import CodeBlock from "./CodeBlock.astro";

const tabs = [
  {
    label: "binary",
    hint: "fastest, no Rust required",
    cmd: "curl -fsSL https://raw.githubusercontent.com/vivekpal1/kdo/main/install.sh | bash -s -- --from-release",
  },
  {
    label: "cargo",
    hint: "explicit version for pre-releases",
    cmd: 'cargo install kdo --version "0.2.0-alpha.1"',
  },
];
---

<section id="install" class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-2xl text-center">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-tide">install</p>
    <h2 class="mt-3 text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
      One command. Two flavors.
    </h2>
    <p class="mt-5 text-lg text-ink-3">
      Pre-<code class="rounded bg-canvas-2 px-1.5 py-0.5 font-mono text-sm text-ink">0.1.0</code>, so cargo
      needs the version flag. Once stable ships, plain
      <code class="rounded bg-canvas-2 px-1.5 py-0.5 font-mono text-sm text-ink">cargo install kdo</code> will work.
    </p>
  </div>

  <div class="mx-auto mt-12 flex max-w-2xl flex-col items-stretch gap-4">
    {
      tabs.map((t, i) => (
        <>
          {i > 0 && (
            <div class="flex items-center gap-3 px-2" aria-hidden="true">
              <span class="h-px flex-1 bg-line"></span>
              <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-3">or</span>
              <span class="h-px flex-1 bg-line"></span>
            </div>
          )}
          <div class="glass rounded-2xl p-5 sm:p-6">
            <div class="flex items-baseline justify-between gap-4">
              <span class="font-mono text-xs uppercase tracking-[0.18em] text-tide">{t.label}</span>
              <span class="text-[11px] text-ink-3">{t.hint}</span>
            </div>
            <div class="mt-4">
              <CodeBlock code={t.cmd} block />
            </div>
          </div>
        </>
      ))
    }
  </div>

  <p class="mx-auto mt-8 text-center text-sm text-ink-3">
    Already installed?
    <code class="rounded bg-canvas-2 px-1.5 py-0.5 font-mono text-sm text-ink">kdo upgrade</code> pulls the
    latest binary in place.
  </p>
</section>

<script>
  // Wire all .copy-btn elements once. Falls back to a hidden textarea for
  // browsers without async clipboard (or when running on http://).
  function fallbackCopy(text: string): boolean {
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.setAttribute("readonly", "");
    ta.style.position = "fixed";
    ta.style.top = "-1000px";
    document.body.appendChild(ta);
    ta.select();
    let ok = false;
    try {
      // Deprecated, but still the only reliable fallback when the async
      // Clipboard API is blocked (http:// origins, some iframes, older Safari).
      // eslint-disable-next-line @typescript-eslint/no-deprecated
      ok = document.execCommand("copy");
    } catch {
      ok = false;
    }
    document.body.removeChild(ta);
    return ok;
  }

  async function copyText(text: string): Promise<boolean> {
    if (navigator.clipboard?.writeText) {
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        // fall through to legacy path
      }
    }
    return fallbackCopy(text);
  }

  function flashCopied(btn: HTMLButtonElement) {
    const copy = btn.querySelector(".copy-icon");
    const check = btn.querySelector(".check-icon");
    if (!copy || !check) return;

    copy.classList.add("hidden");
    check.classList.remove("hidden");
    btn.setAttribute("aria-label", "Copied");

    window.setTimeout(() => {
      copy.classList.remove("hidden");
      check.classList.add("hidden");
      const original = btn.dataset.originalLabel ?? "Copy";
      btn.setAttribute("aria-label", original);
    }, 1500);
  }

  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.dataset.originalLabel = btn.getAttribute("aria-label") ?? "Copy";
    btn.addEventListener("click", async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      const ok = await copyText(text);
      if (ok) flashCopied(btn);
    });
  });
</script>
