---
import CodeBlock from "./CodeBlock.astro";

const agents = [
  {
    label: "claude code",
    title: "Claude Code",
    description:
      "One command registers kdo globally, updates CLAUDE.md with the usage block, and seeds shared memory. Verified — MCP handshake + tool calls round-trip.",
    status: "verified",
    docsHref: "https://vivekpal1.github.io/kdo/docs/mcp#claude-code",
    snippets: [
      {
        caption: "one-command setup",
        code: "kdo setup claude --global",
        lang: "bash",
      },
      {
        caption: "preview first (writes nothing)",
        code: "kdo setup claude --global --dry-run",
        lang: "bash",
      },
    ],
  },
  {
    label: "openclaw",
    title: "OpenClaw",
    description:
      "Installs kdo as an AgentSkills-spec skill and registers the MCP server in ~/.openclaw/openclaw.json. OpenClaw-tuned profile: tighter token budgets, 3-call loop guard, short tool descriptions.",
    status: "supported",
    docsHref: "https://vivekpal1.github.io/kdo/docs/mcp#openclaw",
    snippets: [
      {
        caption: "one-command setup",
        code: "kdo setup openclaw --global",
        lang: "bash",
      },
      {
        caption: "preview first (writes nothing)",
        code: "kdo setup openclaw --global --dry-run",
        lang: "bash",
      },
    ],
  },
];

const statusLabel = (status: string) =>
  status === "verified" ? "tested end-to-end" : "spec-compliant, untested";
---

<section id="agents" class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-2xl text-center">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-tide">use with your agent</p>
    <h2 class="mt-3 text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
      One command wires it up.
    </h2>
    <p class="mt-5 text-lg text-ink-3">
      <code class="rounded bg-canvas-2 px-1.5 py-0.5 font-mono text-sm text-ink">kdo setup</code> registers the MCP server,
      drops in a usage block, seeds shared memory, and tunes the server to the target agent's budget and loop-tolerance.
      Idempotent — safe to re-run.
    </p>
  </div>

  <div class="mx-auto mt-12 grid max-w-4xl gap-4 lg:grid-cols-2">
    {
      agents.map((agent) => (
        <div class="glass flex flex-col rounded-2xl p-5 sm:p-6">
          <div class="flex items-baseline justify-between gap-4">
            <span class="font-mono text-xs uppercase tracking-[0.18em] text-tide">{agent.label}</span>
            <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-ink-3">
              {statusLabel(agent.status)}
            </span>
          </div>

          <h3 class="mt-2 text-xl font-medium tracking-tight text-ink">{agent.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-3">{agent.description}</p>

          <div class="mt-5 flex flex-1 flex-col gap-3">
            {agent.snippets.map((s) => (
              <div>
                <span class="mb-1.5 block font-mono text-[10px] uppercase tracking-[0.18em] text-ink-3">
                  {s.caption}
                </span>
                <CodeBlock code={s.code} lang={s.lang} block />
              </div>
            ))}
          </div>

          <a
            href={agent.docsHref}
            class="mt-4 inline-flex items-center gap-1 text-[11px] text-ink-3 transition-colors duration-100 ease-out hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide"
          >
            MCP reference ↗
          </a>
        </div>
      ))
    }
  </div>

  <div class="mx-auto mt-10 max-w-2xl rounded-2xl border border-line bg-canvas-2/60 px-5 py-4 text-sm text-ink-2">
    <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-tide">other clients</span>
    <p class="mt-2 leading-relaxed text-ink-3">
      Cursor, Zed, Cline, Continue, and anything else speaking the MCP spec — point them at
      <code class="rounded bg-canvas px-1.5 py-0.5 font-mono text-sm text-ink">kdo serve --transport stdio --agent generic</code>.
      No dedicated setup command yet; follow the client's own MCP-server config path.
    </p>
  </div>
</section>
