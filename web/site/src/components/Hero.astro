---
// Hero: bold wordmark with a glass marble overlapping the "k".
// Subtle grid + crosshair markers fade out at the edges.
---

<section class="relative isolate overflow-hidden pt-32 pb-24 sm:pt-40 sm:pb-32">
  <!-- Subtle grid background -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 grid-canvas"></div>

  <!-- Crosshair markers: a hint of technical drawing, nothing more -->
  <span aria-hidden="true" class="crosshair absolute top-[12%] left-[8%]"></span>
  <span aria-hidden="true" class="crosshair absolute top-[18%] right-[10%]"></span>
  <span aria-hidden="true" class="crosshair absolute top-[55%] left-[14%]"></span>
  <span aria-hidden="true" class="crosshair absolute top-[62%] right-[6%]"></span>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <!-- Announcement pill -->
    <div class="fade-up flex justify-center">
      <a
        href="https://github.com/vivekpal1/kdo/releases"
        class="glass inline-flex items-center gap-2 rounded-full px-3.5 py-1.5 text-xs text-ink-2 transition-colors duration-100 ease-out hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide"
      >
        <span aria-hidden="true" class="inline-block h-1.5 w-1.5 rounded-full bg-tide"></span>
        <span>v0.2.0-alpha.1 · agent profiles + loop guards + <code class="font-mono">kdo setup</code></span>
        <span aria-hidden="true" class="text-ink-3">→</span>
      </a>
    </div>

    <!-- Wordmark + marble -->
    <h1 class="fade-up fade-up-d1 mt-10 text-center">
      <span class="relative inline-flex items-baseline justify-center">
        <!-- Glass marble overlapping the 'k' -->
        <span aria-hidden="true" class="float-slow absolute -top-6 -left-2 sm:-top-10 sm:-left-4">
          <span class="marble block h-20 w-20 sm:h-32 sm:w-32 lg:h-40 lg:w-40"></span>
        </span>
        <span class="relative font-sans text-[88px] font-semibold leading-none tracking-[-0.05em] text-ink sm:text-[140px] lg:text-[180px]">
          kdo
        </span>
      </span>
    </h1>

    <p class="fade-up fade-up-d2 mx-auto mt-8 max-w-2xl text-center text-xl leading-snug text-ink-2 sm:text-2xl sm:leading-snug">
      Workspace runtime for AI coding agents.
      <br class="hidden sm:block" />
      <span class="text-ink-3">Stop your agent from burning tokens exploring your repo.</span>
    </p>

    <!-- CTAs -->
    <div class="fade-up fade-up-d3 mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        href="#install"
        class="rounded-full bg-ink px-5 py-3 text-sm font-medium text-canvas transition-transform duration-100 ease-out hover:scale-[1.02] active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide"
      >
        Get started
      </a>
      <a
        href="https://github.com/vivekpal1/kdo"
        class="glass inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm font-medium text-ink-2 transition-colors duration-100 ease-out hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide"
      >
        <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        Star on GitHub
      </a>
    </div>

    <!-- Floating terminal -->
    <div class="fade-up fade-up-d3 mt-20 flex justify-center">
      <slot name="terminal" />
    </div>
  </div>
</section>
