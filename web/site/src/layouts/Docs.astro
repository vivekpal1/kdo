---
import Base from "./Base.astro";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description?: string;
  /** Path within /docs — e.g. "getting-started" */
  slug: string;
}

const { title, description, slug } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "") || "";

const nav = [
  {
    section: "Start",
    items: [
      { slug: "", label: "Introduction" },
      { slug: "getting-started", label: "Getting started" },
    ],
  },
  {
    section: "Reference",
    items: [
      { slug: "cli", label: "CLI commands" },
      { slug: "config", label: "kdo.toml schema" },
      { slug: "mcp", label: "MCP server" },
    ],
  },
];

const pageTitle = `${title} · kdo docs`;
---

<Base title={pageTitle} description={description}>
  <Header />

  <div class="relative mx-auto grid max-w-7xl gap-10 px-4 pt-32 pb-24 sm:px-6 sm:pt-40 lg:grid-cols-[240px_1fr]">
    <!-- Sidebar -->
    <aside class="sticky top-28 hidden h-max self-start lg:block" aria-label="Documentation navigation">
      <nav class="glass rounded-2xl p-4">
        <a
          href={`${base}/docs`}
          class="mb-4 flex items-center gap-2 rounded-lg px-2 py-1.5 text-sm font-medium text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide"
        >
          <span aria-hidden="true" class="relative inline-block h-4 w-4">
            <span class="marble absolute inset-0"></span>
          </span>
          Docs
        </a>

        {
          nav.map((group) => (
            <div class="mb-4 last:mb-0">
              <h3 class="px-2 mb-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-ink-3">
                {group.section}
              </h3>
              <ul class="space-y-0.5">
                {group.items.map((item) => {
                  const href = item.slug === "" ? `${base}/docs` : `${base}/docs/${item.slug}`;
                  const isActive = item.slug === slug;
                  return (
                    <li>
                      <a
                        href={href}
                        class={`block rounded-lg px-2 py-1.5 text-sm transition-colors duration-100 ease-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide ${
                          isActive
                            ? "bg-canvas-2 text-ink font-medium"
                            : "text-ink-2 hover:bg-canvas-2/60 hover:text-ink"
                        }`}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }

        <div class="mt-6 border-t border-line pt-4">
          <a
            href="https://github.com/vivekpal1/kdo"
            class="block rounded-lg px-2 py-1.5 text-xs text-ink-3 transition-colors duration-100 ease-out hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide"
          >
            GitHub ↗
          </a>
          <a
            href="https://github.com/vivekpal1/kdo/blob/main/CHANGELOG.md"
            class="block rounded-lg px-2 py-1.5 text-xs text-ink-3 transition-colors duration-100 ease-out hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide"
          >
            Changelog ↗
          </a>
        </div>
      </nav>
    </aside>

    <!-- Content -->
    <main class="min-w-0">
      <!-- Mobile nav: inline dropdown-like pill row -->
      <nav class="mb-8 flex flex-wrap gap-1.5 lg:hidden" aria-label="Documentation navigation">
        {
          nav.flatMap((g) => g.items).map((item) => {
            const href = item.slug === "" ? `${base}/docs` : `${base}/docs/${item.slug}`;
            const isActive = item.slug === slug;
            return (
              <a
                href={href}
                class={`rounded-full border px-3 py-1.5 text-xs transition-colors duration-100 ease-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-tide ${
                  isActive
                    ? "border-ink bg-ink text-canvas"
                    : "border-line bg-canvas text-ink-2 hover:border-ink-3 hover:text-ink"
                }`}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>

      <article class="prose-kdo">
        <header class="mb-8 border-b border-line pb-6">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-tide">kdo documentation</p>
          <h1 class="mt-2 text-4xl font-semibold tracking-tight text-ink sm:text-5xl">{title}</h1>
          {description && <p class="mt-4 max-w-2xl text-lg text-ink-3">{description}</p>}
        </header>
        <slot />
      </article>
    </main>
  </div>
</Base>

<style is:global>
  /* Prose styles for the MDX content. Uses our tokens, not Tailwind's prose plugin. */
  .prose-kdo {
    color: var(--color-ink-2);
    line-height: 1.65;
  }
  .prose-kdo > * + * {
    margin-top: 1.25em;
  }
  .prose-kdo h2 {
    color: var(--color-ink);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line);
  }
  .prose-kdo h3 {
    color: var(--color-ink);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-kdo h4 {
    color: var(--color-ink);
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .prose-kdo p {
    color: var(--color-ink-2);
  }
  .prose-kdo strong {
    color: var(--color-ink);
    font-weight: 600;
  }
  .prose-kdo a {
    color: var(--color-tide);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .prose-kdo a:hover {
    color: var(--color-ink);
  }
  .prose-kdo code:not(pre code) {
    background: var(--color-canvas-2);
    color: var(--color-ink);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: var(--font-mono);
  }
  .prose-kdo pre {
    background: var(--color-canvas-2) !important;
    border: 1px solid var(--color-line);
    border-radius: 0.75rem;
    padding: 1rem 1.125rem;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.55;
    margin: 1.25rem 0;
  }
  .prose-kdo pre code {
    background: transparent;
    padding: 0;
    font-family: var(--font-mono);
  }
  .prose-kdo ul, .prose-kdo ol {
    padding-left: 1.25rem;
    color: var(--color-ink-2);
  }
  .prose-kdo ul { list-style-type: disc; }
  .prose-kdo ol { list-style-type: decimal; }
  .prose-kdo li { margin-top: 0.35rem; }
  .prose-kdo li::marker { color: var(--color-ink-3); }

  .prose-kdo table {
    width: 100%;
    font-size: 0.875rem;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  .prose-kdo th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-ink);
    font-weight: 500;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .prose-kdo td {
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-ink-2);
    vertical-align: top;
  }
  .prose-kdo td code { white-space: nowrap; }

  .prose-kdo blockquote {
    border-left: 2px solid var(--color-tide);
    background: color-mix(in oklch, var(--color-tide-soft) 20%, transparent);
    padding: 0.75rem 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-ink-2);
    font-style: normal;
  }
  .prose-kdo blockquote p:first-child { margin-top: 0; }

  .prose-kdo hr {
    border: none;
    border-top: 1px solid var(--color-line);
    margin: 2.5rem 0;
  }

  /* Shiki code blocks: kill the default background so ours wins */
  .prose-kdo pre.astro-code { background: var(--color-canvas-2) !important; }
  .prose-kdo pre.astro-code span { background: transparent !important; }
</style>
